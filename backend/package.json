{
  "name": "assetflow-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:generate": "prisma generate --schema src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "db:seed": "prisma db seed --schema src/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "node src/prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1085.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.46.0",
    "qrcode": "^1.5.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
}

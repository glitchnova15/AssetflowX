DATABASE_URL="postgresql://assetflow:change-me@localhost:5432/assetflow?schema=public"
PORT=4000
JWT_ACCESS_SECRET="replace-with-a-32-character-minimum-access-secret"
JWT_REFRESH_SECRET="replace-with-a-different-32-character-minimum-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS=12
# AWS Configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_USE_LOCAL="false"

# Amazon S3
S3_BUCKET_NAME="your-s3-bucket-name"

# Amazon SES
SES_FROM_EMAIL="your-verified-ses-email@example.com"
